# Exemplo de variáveis de ambiente para o monorepo my-hub-monorepo
# Copie este arquivo para .env e ajuste conforme seu ambiente local ou K8s

# ------------------------------------------------------------------
# RabbitMQ (usado por hub-principal e integracoes)
# ------------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ------------------------------------------------------------------
# MongoDB Central (collection de agendamentos do HUB)
# ------------------------------------------------------------------
CENTRAL_MONGO_URL=mongodb://localhost:27017

# ------------------------------------------------------------------
# MongoDB dos Tenants (database-per-tenant)
# As integracoes usam esse cluster e alternam para o database informado
# no campo TenantDB do evento, ex: messageAutomation_clienteA
# ------------------------------------------------------------------
TENANT_MONGO_URL=mongodb://localhost:27017
